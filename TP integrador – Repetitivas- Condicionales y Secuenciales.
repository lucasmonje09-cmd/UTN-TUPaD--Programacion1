#EJE4

# --- Inicialización de variables ---
energia = 100
tiempo = 12
cerraduras_abiertas = 0
alarma = False
codigo_parcial = ""
forzar_seguidas = 0

# --- Validación del nombre ---
nombre_agente = input("Ingrese el nombre del agente: ")
while not nombre_agente.isalpha():
    print("Error: El nombre solo debe contener letras.")
    nombre_agente = input("Ingrese el nombre del agente: ")

print(f"\n--- Bienvenido Agente {nombre_agente} a 'La Bóveda' ---")

# --- Bucle principal del juego ---
# El juego sigue si hay energía, tiempo, faltan cerraduras y no se bloqueó por alarma crítica
while energia > 0 and tiempo > 0 and cerraduras_abiertas < 3:
    
    # Verificación de regla de bloqueo por alarma
    if alarma and tiempo <= 3:
        print("\n¡SISTEMA BLOQUEADO! La alarma notificó a seguridad y el tiempo es insuficiente.")
        break

    # Mostrar estado actual
    print("-" * 30)
    print(f"ESTADO: Energía: {energia} | Tiempo: {tiempo} | Cerraduras: {cerraduras_abiertas}/3")
    print(f"Alarma: {'ACTIVADA' if alarma else 'Desactivada'} | Código: [{codigo_parcial}]")
    print("-" * 30)
    
    print("1. Forzar cerradura (-20 energía, -2 tiempo)")
    print("2. Hackear panel (-10 energía, -3 tiempo)")
    print("3. Descansar (+15 energía, -1 tiempo)")
    
    opcion = input("Seleccione una acción: ")
    while not opcion.isdigit() or opcion not in ["1", "2", "3"]:
        opcion = input("Opción inválida. Elija 1, 2 o 3: ")
    
    # --- Lógica de Opciones ---
    
    if opcion == "1":
        # Costos y racha
        energia -= 20
        tiempo -= 2
        forzar_seguidas += 1
        
        # Regla Anti-Spam
        if forzar_seguidas == 3:
            alarma = True
            print("¡AVISO! Intentaste forzar demasiadas veces seguidas. La cerradura se trabó y la ALARMA se activó.")
        else:
            # Riesgo de alarma si energía < 40
            detectado = False
            if energia < 40:
                print("¡ALERTA! Energía baja, riesgo de activar alarma.")
                riesgo = input("Elija un número del 1 al 3 para calibrar el esfuerzo: ")
                while not riesgo.isdigit() or riesgo not in ["1", "2", "3"]:
                    riesgo = input("Error. Ingrese un número del 1 al 3: ")
                
                if riesgo == "3":
                    alarma = True
                    print("¡Hiciste demasiado ruido! Alarma activada.")
                    detectado = True
            
            # Si no saltó la alarma ahora ni estaba trabada por racha, abre cerradura
            if not alarma or (alarma and not detectado and forzar_seguidas < 3):
                 cerraduras_abiertas += 1
                 print("¡Cerradura forzada con éxito!")

    elif opcion == "2":
        # Hackear panel
        forzar_seguidas = 0 # Rompe la racha
        energia -= 10
        tiempo -= 3
        
        print("Hackeando...")
        for i in range(1, 5):
            codigo_parcial += "A"
            print(f"Paso {i}/4 - Progreso: {codigo_parcial}")
            
        if len(codigo_parcial) >= 8:
            if cerraduras_abiertas < 3:
                cerraduras_abiertas += 1
                print("¡El código está completo! Se abrió una cerradura automáticamente.")
                # Opcional: resetear código tras abrir para poder hackear otra
                codigo_parcial = "" 

    elif opcion == "3":
        # Descansar
        forzar_seguidas = 0 # Rompe la racha
        tiempo -= 1
        recuperacion = 15
        
        if alarma:
            recuperacion -= 10
            print("Es difícil descansar con el ruido de la alarma...")
            
        energia += recuperacion
        if energia > 100:
            energia = 100
        print(f"Descanso finalizado. Energía actual: {energia}")

# --- Condiciones de Fin de Juego ---
print("\n" + "="*30)
if cerraduras_abiertas >= 3:
    print(f"¡VICTORIA! El agente {nombre_agente} ha abierto la bóveda.")
elif alarma and tiempo <= 3:
    print("DERROTA: El sistema se bloqueó por seguridad.")
elif energia <= 0:
    print("DERROTA: Te quedaste sin energía y te desmayaste.")
elif tiempo <= 0:
    print("DERROTA: Se terminó el tiempo de la misión.")
print("="*30)



