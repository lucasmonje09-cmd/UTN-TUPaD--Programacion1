# 1. Pedir nombre del cliente
while True:
    nombre = input("Ingrese el nombre del cliente: ").strip()
    if nombre.isalpha():
        break
    else:
        print("Error: El nombre debe contener solo letras y no puede estar vacío.")

# 2. Pedir cantidad de productos
while True:
    cantidad_str = input("Cantidad de productos a comprar: ")
    if cantidad_str.isdigit() and int(cantidad_str) > 0:
        cantidad = int(cantidad_str)
        break
    else:
        print("Error: La cantidad debe ser un número entero mayor a 0.")

total_sin_descuento = 0
total_con_descuento = 0

# 3. Procesar cada producto
for i in range(1, cantidad + 1):
    # Pedir precio
    while True:
        precio_str = input(f"Producto {i} - Precio: ")
        if precio_str.isdigit():
            precio = int(precio_str)
            break
        else:
            print("Error: Ingrese un precio válido (número entero).")
            
    while True:
        tiene_descuento = input(f"Producto {i} - Descuento (S/N): ").lower()
        if tiene_descuento in ['s', 'n']:
            break
        else:
            print("Error: Ingrese 's' para sí o 'n' para no.")
    
    total_sin_descuento += precio
    
    if tiene_descuento == 's':
        precio_final = precio * 0.9
    else:
        precio_final = float(precio)
        
    total_con_descuento += precio_final

# 4. Cálculos finales y salida
ahorro = total_sin_descuento - total_con_descuento
promedio = total_con_descuento / cantidad

print("\n--- Resumen de Compra ---")
print(f"Cliente: {nombre}")
print(f"Cantidad de productos: {cantidad}")
print(f"Total sin descuentos: ${total_sin_descuento}")
print(f"Total con descuentos: ${total_con_descuento:.2f}")
print(f"Ahorro: ${ahorro:.2f}")
print(f"Promedio por producto: ${promedio:.2f}")





